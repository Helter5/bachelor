# Database Configuration
DATABASE_NAME=arena_db
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_ECHO=false  # Set to true to enable SQL query logging (development only)

# Arena API Configuration (required for backend)
# Use host.docker.internal to access services running on host from Docker
ARENA_BASE_URL=http://host.docker.internal:8080
ARENA_CLIENT_ID=your_client_id
ARENA_CLIENT_SECRET=your_client_secret
ARENA_API_KEY=your_api_key
ARENA_API_FORMAT=json

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=False

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend Configuration
FRONTEND_PORT=80
VITE_API_URL=http://localhost:8000  # Backend API URL for frontend

# pgAdmin Configuration
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Arena Local Instance Configuration (optional)
PHP_MEMORY_LIMIT=256M
