# Frontend Dockerfile - Development
FROM node:20-alpine

WORKDIR /app

# Copy package files first for better layer caching
COPY package.json package-lock.json* ./
# Copy config files into image to avoid VirtioFS read errors on macOS
COPY vite.config.ts tsconfig.json tsconfig.app.json index.html ./

# Install dependencies (cached unless package files change)
RUN npm install --legacy-peer-deps

# Copy application code into the image so Vite does not read from a macOS bind mount.
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Run Vite dev server with hot-reload
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
